# ANCHOR - Environment Configuration

# -----------------
# API & Web Server
# -----------------
PORT=3000
HOST=0.0.0.0

# -----------------
# Security
# -----------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=super_secret_anchor_dev_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$wT.fG6jS6xP7X/b/rL2oDO8t.Fk6gK1Cj/Y.hK/I1F8VvB1zV9s.u # "admin"

# -----------------
# Cluster Configuration
# -----------------
# For multi-node deployments
NODE_AGENT_PORT=3001
NODE_AGENT_HOST=0.0.0.0
CONTROLLER_URL=http://controller-host:3000
NODE_ID=node-1
NODE_REGION=us-east
# DOCKER_HOST=tcp://127.0.0.1:2375

# -----------------
# Logging & Debug
# -----------------
LOG_LEVEL=info

# -----------------
# AI Scaling Engine
# -----------------
# Scaling check interval in milliseconds (default: 30000 = 30 seconds)
SCALING_CHECK_INTERVAL=30000

# Scale up when utilization exceeds this threshold (default: 0.8 = 80%)
SCALE_UP_THRESHOLD=0.8

# Scale down when utilization drops below this threshold (default: 0.2 = 20%)
SCALE_DOWN_THRESHOLD=0.2

# Idle timeout before shutting down servers for cost optimization (default: 1200000 = 20 minutes)
IDLE_TIMEOUT=1200000

# Enable predictive scaling based on historical patterns (default: true)
PREDICTIVE_SCALING=true

# -----------------
# Plugin Ecosystem
# -----------------
# Directory where plugins are located
PLUGIN_DIR=./plugins
