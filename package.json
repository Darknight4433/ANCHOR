{
  "name": "process-manager",
  "version": "1.0.0",
  "description": "A lightweight Node.js process manager for starting, stopping, restarting processes with PID and uptime tracking",
  "main": "src/index.js",
  "bin": {
    "pm": "bin/cli.js",
    "pm-daemon": "bin/daemon.js",
    "pm-client": "bin/daemon-client.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "daemon": "node bin/daemon.js",
    "platform": "node bin/platform.js",
    "test": "node examples/test.js",
    "test:integration": "node examples/integration-test.js",
    "example": "node examples/example.js",
    "infrastructure": "node examples/infrastructure.js",
    "platform-demo": "node examples/platform-demo.js",
    "install-service": "sudo bash install.sh"
  },
  "keywords": ["process-manager", "pm2", "process", "orchestration", "game-servers", "docker"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=12.0.0"
  },
  "dependencies": {
    "body-parser": "^1.20.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "ws": "^8.13.0",
    "yaml": "^2.3.0"
  }
}
